# wa-dispatch configuration — copy to `config.env` and edit.
#   cp config.example.env config.env
# config.env is gitignored: it holds hostnames and secret paths, not secrets.

# ── Where the WhatsApp bridge lives ──────────────────────────────────────────
# The bridge is whatsapp-mcp-pro's Go daemon (or any fork exposing the same
# SQLite store + /api/send). Two supported topologies:
#
#   local  — bridge runs on this same machine (simplest; start here)
#   ssh    — bridge runs on another box you can reach passwordlessly over SSH
#            (Simon's setup: laptop runs the sessions, a mini runs the bridge)
BRIDGE_MODE=local

# Only used when BRIDGE_MODE=ssh. Must work non-interactively: `ssh <host> true`
BRIDGE_SSH_HOST=

# Path to the bridge's message store, ON THE MACHINE THE BRIDGE RUNS ON.
BRIDGE_DB=~/whatsapp-mcp-pro/whatsapp-bridge/store/messages.db

# Bridge REST API, as reachable from wherever wa-approve runs.
BRIDGE_API=http://127.0.0.1:8080

# File containing the bridge's API_KEY (or the bridge .env itself — the key is
# parsed out of an API_KEY= line). Never commit this file.
BRIDGE_ENV_FILE=~/whatsapp-mcp-pro/.env

# ── Dispatcher ───────────────────────────────────────────────────────────────
POLL_SECONDS=20
# Minutes before the same project may start another prepare-run. Batches bursts
# so a chatty thread produces one considered run, not twenty.
DEFAULT_COOLDOWN_MIN=10

# The claude binary. `which claude` — launchd does not inherit your shell PATH.
CLAUDE_BIN=~/.npm-global/bin/claude

# Extra flags for spawned sessions. Simon runs --dangerously-skip-permissions
# because the deny hook is the real safety floor; leave empty to keep normal
# permission prompts (safer, but an unattended run will stall on the first one).
CLAUDE_FLAGS=--dangerously-skip-permissions

# ── Approval service (optional but recommended) ──────────────────────────────
# Lets you approve drafted replies from your phone. Set ENABLED=false to skip.
APPROVE_ENABLED=true

# Address wa-approve binds. MUST be a private address your phone can reach —
# a VPN/tailnet IP, or 127.0.0.1 if you only ever approve from that machine.
# NEVER 0.0.0.0: this endpoint can send WhatsApp messages.
APPROVE_BIND=127.0.0.1
APPROVE_PORT=8086

# How the phone reaches wa-approve (goes into the notification buttons).
APPROVE_PUBLIC_URL=http://127.0.0.1:8086

# Hours a pending draft stays approvable before it expires.
APPROVE_TTL_HOURS=12

# ── ntfy (how drafts reach your phone) ───────────────────────────────────────
# Any ntfy server: ntfy.sh or self-hosted. Leave NTFY_TOPIC empty to disable
# push entirely (drafts still queue; you approve via the /d/<id> URL).
NTFY_URL=http://127.0.0.1:2586
NTFY_TOPIC_FILE=~/.config/wa-dispatch/ntfy-topic
NTFY_TOKEN_FILE=~/.config/wa-dispatch/ntfy-token

# ── Meetings (optional, meet-dispatch) ───────────────────────────────────────
# File containing a Fathom API key (fathom.video/api_clients/new). Leave empty
# to disable the meeting pipeline. One transcript is split across the projects
# it actually discussed, then each slice is delivered to that project's session.
FATHOM_KEY_FILE=
MEET_POLL_SECONDS=300
