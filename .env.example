# WhatsApp MCP Extended - Environment Variables
# Copy this file to .env and fill in the values

# REQUIRED: API authentication key
# Generate with: openssl rand -hex 32
API_KEY=CHANGEME_USE_openssl_rand_hex_32

# Development mode: Set to "true" to disable API_KEY requirement
# WARNING: Never use in production!
DISABLE_AUTH_CHECK=false

# Optional: Additional CORS origins (comma-separated)
# CORS_ORIGINS=https://your-domain.com,https://another-domain.com

# Optional: Bind host for the bridge REST API (default: 127.0.0.1 for local dev; set 0.0.0.0 in Docker)
# API_BIND_HOST=127.0.0.1

# Optional: Disable security checks for development
# WARNING: Never use in production!
# DISABLE_SSRF_CHECK=false
# DISABLE_PATH_CHECK=false

# Optional: Presence ping (PRESENCE_PING_ENABLED=false to stop appearing online to contacts)
# PRESENCE_PING_ENABLED=true
# PRESENCE_PING_INTERVAL=20m

# Optional: Override the SQLite store directory used by the MCP server.
# Default: /app/store (Docker) → <repo>/whatsapp-bridge/store (local) → <repo>/store
# WA_STORE_PATH=/path/to/store

# Optional: Skip the import-time check that messages.db exists. Set to "1" only for tests/lint.
# WA_SKIP_DB_CHECK=0

# ── MCP server ───────────────────────────────────────────────────────────────
# Which tool groups the MCP server exposes. Comma-separated, or "all".
# The pro toolsets are opt-in and off by default:
#   recall  — semantic search over history   (needs: uv sync --extra pro)
#   audio   — local voice-note transcription (needs: uv sync --extra pro)
#   inbox   — check_inbox, "what arrived since I last asked"
# WHATSAPP_MCP_TOOLSETS=all

# ── Account safety (opt-in) ──────────────────────────────────────────────────
# Humanized send pacing: randomized delays + typing simulation before a send.
# Off by default; read the account-safety section of the README before enabling.
# ANTIBAN_ENABLED=true

# Hard allowlist of chats the bridge will EVER send to (comma-separated JIDs).
# Unset means no restriction. Worth setting before pointing automation at this.
# SEND_ALLOWED_JIDS=1203xxxxxxxxxxxxxxx@g.us,4477xxxxxxx@s.whatsapp.net

# ── Presence ─────────────────────────────────────────────────────────────────
# Broadcasting "available" tells WhatsApp this device is actively reading, which
# SUPPRESSES push notifications on your phone. Off by default for that reason.
# PRESENCE_PING_ENABLED=true
