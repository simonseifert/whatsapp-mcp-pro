# WhatsApp MCP Extended - Environment Variables
# Copy this file to .env and fill in the values

# REQUIRED: API authentication key
# Generate with: openssl rand -hex 32
API_KEY=CHANGEME_USE_openssl_rand_hex_32

# Development mode: Set to "true" to disable API_KEY requirement
# WARNING: Never use in production!
DISABLE_AUTH_CHECK=false

# Optional: Additional CORS origins (comma-separated)
# CORS_ORIGINS=https://your-domain.com,https://another-domain.com

# Optional: Bind host for the bridge REST API (default: 127.0.0.1 for local dev; set 0.0.0.0 in Docker)
# API_BIND_HOST=127.0.0.1

# Optional: Disable security checks for development
# WARNING: Never use in production!
# DISABLE_SSRF_CHECK=false
# DISABLE_PATH_CHECK=false

# Optional: Presence ping (PRESENCE_PING_ENABLED=false to stop appearing online to contacts)
# PRESENCE_PING_ENABLED=true
# PRESENCE_PING_INTERVAL=20m

# Optional: Override the SQLite store directory used by the MCP server.
# Default: /app/store (Docker) → <repo>/whatsapp-bridge/store (local) → <repo>/store
# WA_STORE_PATH=/path/to/store

# Optional: Skip the import-time check that messages.db exists. Set to "1" only for tests/lint.
# WA_SKIP_DB_CHECK=0
